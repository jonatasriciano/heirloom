# ============================================
# Heirloom - Environment Configuration
# ============================================
# Copy to .env.local for development/production
# NEVER commit .env.local to version control
# ============================================

# -----------------------------------------------------------------------------
# CMS Integration (REQUIRED)
# -----------------------------------------------------------------------------
# Internal URL (for server-side requests within Docker network)
CMS_INTERNAL_URL=http://fusion-cms:3000

# Public URL (for client-side requests)
NEXT_PUBLIC_CMS_URL=http://localhost:3000

# API Key for CMS authentication
CMS_API_KEY=your-cms-api-key-here

# -----------------------------------------------------------------------------
# Public URLs (REQUIRED)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3011
NEXT_PUBLIC_COMPANY_SLUG=heirloom

# -----------------------------------------------------------------------------
# Cache Revalidation (REQUIRED)
# -----------------------------------------------------------------------------
# Must match REVALIDATE_SECRET in Fusion CMS
REVALIDATE_SECRET=your-revalidate-secret-here

# -----------------------------------------------------------------------------
# Development Only
# -----------------------------------------------------------------------------
# NODE_ENV=development
# PORT=3011
