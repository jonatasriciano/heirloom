{
  "name": "heirloom",
  "version": "1.0.0",
  "description": "Heirloom Rug Cleaning website - Next.js version",
  "private": true,
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "dev": "next dev -p 3011",
    "dev:clean": "rm -rf .next && rm -rf node_modules/.cache && next dev -p 3011",
    "build": "NODE_ENV=production TURBOPACK=0 next build",
    "prebuild": "node scripts/generate-sitemap-pages.js",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "type-check": "tsc --noEmit",
    "validate": "npm run type-check && npm run lint",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "docker:build": "./docker.sh build",
    "docker:run": "./docker.sh run",
    "docker:up": "./docker.sh up",
    "docker:up:prod": "./docker.sh up:prod",
    "docker:down": "./docker.sh down",
    "docker:test": "./docker.sh test",
    "docker:logs": "./docker.sh logs",
    "docker:clean": "./docker.sh clean"
  },
  "dependencies": {
    "axios": "^1.13.4",
    "dotenv": "^17.2.3",
    "glob": "^13.0.6",
    "next": "16.1.6",
    "next-intl": "^4.8.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.30",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
